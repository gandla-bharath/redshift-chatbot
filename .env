# ── Database Config ────────────────────────────────
# For LOCAL development (PostgreSQL via Docker)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=datawarehouse
DB_USER=admin
DB_PASSWORD=admin123

# ── Ollama Config ──────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── AWS Config (only needed when migrating to AWS) ─
# AWS_REGION=us-east-1
# REDSHIFT_CLUSTER_ID=your-cluster-id
# REDSHIFT_DB=your_database
# REDSHIFT_DB_USER=your_user
# REDSHIFT_SECRET_ARN=arn:aws:secretsmanager:...
# BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# ── App Config ─────────────────────────────────────
MAX_ROWS=50
LOG_LEVEL=INFO
CACHE_THRESHOLD=0.85
