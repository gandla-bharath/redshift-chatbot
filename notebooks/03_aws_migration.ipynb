   "source": [
    "# ☁️ Notebook 3 — Migrate to AWS (Bedrock + Redshift)\n",
    "Switch from local Ollama+PostgreSQL → AWS Bedrock+Redshift with 3 env var changes."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 1 — Update your .env file:\n",
    "# DB_MODE=aws\n",
    "# LLM_MODE=aws\n",
    "# AWS_REGION=us-east-1\n",
    "# REDSHIFT_CLUSTER_ID=your-cluster-id\n",
    "# REDSHIFT_DB=your_database\n",
    "# REDSHIFT_DB_USER=your_user\n",
    "# BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0\n",
    "\n",
    "import sys, os\n",
    "sys.path.insert(0, os.path.abspath('..'))\n",
    "\n",
    "from dotenv import load_dotenv\n",
    "load_dotenv(override=True)\n",
    "\n",
    "print('DB_MODE :', os.getenv('DB_MODE'))\n",
    "print('LLM_MODE:', os.getenv('LLM_MODE'))\n",
    "print('Region  :', os.getenv('AWS_REGION'))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 2 — Test AWS credentials\n",
    "import boto3\n",
    "sts = boto3.client('sts')\n",
    "identity = sts.get_caller_identity()\n",
    "print('Account:', identity['Account'])\n",
    "print('Role   :', identity['Arn'])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 3 — Test Redshift Data API\n",
    "from src.db import test_connection\n",
    "ok = test_connection()\n",
    "print('✅ Redshift connected!' if ok else '❌ Check cluster ID, IAM role, and region')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 4 — Test Bedrock access\n",
    "import boto3, json\n",
    "bedrock = boto3.client('bedrock-runtime', region_name=os.getenv('AWS_REGION', 'us-east-1'))\n",
    "\n",
    "resp = bedrock.converse(\n",
    "    modelId=os.getenv('BEDROCK_MODEL_ID'),\n",
    "    messages=[{'role': 'user', 'content': 'Say: Bedrock is working'}]\n",
    ")\n",
    "print(resp['output']['message']['content'][0]['text'])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 5 — Full AWS chatbot (Bedrock + Redshift)\n",
    "from src.db import run_query, get_schema\n",
    "from src.llm import chat_bedrock\n",
    "\n",
    "schema = get_schema()  # pulls from Redshift now\n",
    "\n",
    "def ask_aws(question: str):\n",
    "    print(f'\\n❓ {question}')\n",
    "    print('─' * 60)\n",
    "    answer = chat_bedrock(\n",
    "        user_message=question,\n",
    "        schema=schema,\n",
    "        run_query_fn=lambda sql: run_query(sql).to_string(index=False)\n",
    "    )\n",
    "    print(f'💬 {answer}')\n",
    "\n",
    "ask_aws('What are the top 5 properties by total booking revenue?')"
   ]
  }
